# IceCharts Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# License Configuration (Required for Production)
# ============================================================================
LICENSE_KEY=PENG-XXXX-XXXX-XXXX-XXXX-ABCD
PRODUCT_NAME=icecharts
LICENSE_SERVER_URL=https://license.penguintech.io
RELEASE_MODE=false

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
POSTGRES_DB=icecharts
POSTGRES_USER=icecharts_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# PyDAL Database Configuration
DB_TYPE=postgres
DB_POOL_SIZE=10

# ============================================================================
# Redis Cache Configuration
# ============================================================================
REDIS_PASSWORD=changeme
REDIS_PORT=6379
REDIS_URL=redis://:changeme@redis:6379/0

# ============================================================================
# MinIO Object Storage Configuration
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=icecharts
MINIO_SECURE=false
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# ============================================================================
# Application Ports
# ============================================================================
API_PORT=4000
WEB_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ============================================================================
# Flask Backend Configuration
# ============================================================================
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=changeme-in-production
SECURITY_PASSWORD_SALT=changeme-salt-in-production

# JWT Configuration
JWT_SECRET_KEY=changeme-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@icecharts.local
DEFAULT_ADMIN_PASSWORD=admin123

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# React Frontend Configuration
# ============================================================================
NODE_ENV=production
REACT_APP_API_URL=http://localhost:4000
REACT_APP_API_BASE_PATH=/api/v1
REACT_APP_MINIO_URL=http://localhost:9000

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/icecharts.log
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10

# ============================================================================
# Security Configuration
# ============================================================================
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
TLS_ENABLED=false
TLS_CERT_PATH=/etc/ssl/certs/server.crt
TLS_KEY_PATH=/etc/ssl/private/server.key

# ============================================================================
# Google OAuth2 Configuration
# ============================================================================
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select an existing one
# 3. Enable the Google+ API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized JavaScript origins and redirect URIs:
#    - JavaScript origins: http://localhost:3000, https://yourdomain.com
#    - Redirect URIs: http://localhost:3000/login, https://yourdomain.com/login
# 6. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/login

# ============================================================================
# Email Configuration (Optional)
# ============================================================================
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=noreply@icecharts.local
SMTP_TLS=true

# ============================================================================
# Monitoring Configuration (Optional - use --profile monitoring)
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================================================
# Docker Configuration
# ============================================================================
COMPOSE_PROJECT_NAME=icecharts
DOCKER_BUILDKIT=1

# ============================================================================
# Performance Configuration
# ============================================================================
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30s
IDLE_TIMEOUT=15m
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_TTL=300
CACHE_MAX_SIZE=1000
CACHE_CLEANUP_INTERVAL=60s

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_ENTERPRISE_REPORTS=false
FEATURE_USER_MANAGEMENT=true

# ============================================================================
# Development Tools
# ============================================================================
DEBUG=false
ENABLE_PROFILING=false
METRICS_ENABLED=true

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================================================
# Testing Configuration
# ============================================================================
TEST_DATABASE_URL=postgresql://icecharts_user:test_password@localhost:5432/test_icecharts
TEST_REDIS_URL=redis://:test_password@localhost:6379/15
